# ── LoveSupremacy Universe 环境变量模板 ──────────────────
# 复制此文件为 .env 并填入实际值

# ================= Telegram Bot 配置 =================
TELEGRAM_TOKEN=
YOUR_CHAT_ID=0

# ================= LLM 对话服务配置 (多平台免费路由) =================
# 主力: OpenRouter 免费池
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto

# 国内极速池
SILICONFLOW_API_KEY=
SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V3

# 商汤日日新
SENSENOVA_API_KEY=
SENSENOVA_MODEL=SenseChat-Turbo

# 国际兜底池 (仅限 gemini-2.5-flash，严禁 Pro)
GEMINI_API_KEY=

# 通用 AI 配置（兼容旧代码）
AI_API_BASE=https://openrouter.ai/api/v1
AI_API_KEY=
AI_MODEL=openrouter/auto

# ================= 生图服务配置 (SDXL 1.0 LoRA) =================
# HuggingFace Spaces (主力，挂载专属 LoRA)
HF_SPACE_API_URL=https://your-username-sdxl-lora.hf.space
LORA_TRIGGER_WORD=your_lora_trigger_word
LORA_FILE_NAME=your_lora_name.safetensors

# SiliconFlow SDXL (兜底)
SILICONFLOW_IMAGE_MODEL=stabilityai/stable-diffusion-xl-base-1.0

# OpenRouter SD3 (备选)
OPENROUTER_IMAGE_MODEL=stabilityai/stable-diffusion-3-medium

# ================= 服务配置 =================
DATA_DIR=/opt/NxSiran-Telegram-Bot/data
PORT=8080
PUBLIC_URL=
ADMIN_USERNAME=

# ================= 可选服务 =================
# Relay API
RELAY_API_KEY=

# 本地 TTS 服务 (GPT-SoVITS / CosyVoice / Edge TTS)
TTS_BACKEND=sovits
LOCAL_TTS_URL=http://127.0.0.1:9880

# 角色进化系统
EVOLUTION_MODEL=deepseek/deepseek-r1:free

# GitHub Webhook 自动部署
GITHUB_WEBHOOK_SECRET=
